{
  "name": "llmeter",
  "version": "0.1.0",
  "description": "Local token usage monitor for Claude Code and Codex",
  "license": "MIT",
  "bin": {
    "llmeter": "bin/llmeter.js"
  },
  "files": [
    "bin",
    "docs",
    "launchd",
    "scripts",
    "llmeter",
    "README.md",
    "requirements.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepack": "find llmeter -name __pycache__ -type d -prune -exec rm -rf {} +",
    "test": "node bin/llmeter.js --help"
  },
  "keywords": [
    "llm",
    "tokens",
    "claude-code",
    "codex",
    "litellm"
  ]
}
